{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "https://github.com/SamuraiWriter7/kazene-memory-breathing-protocol/schemas/structural-rumination-record.schema.json",
"title": "Structural Rumination Record",
"description": "A structural rumination record for Kazene Memory Breathing Protocol, documenting how a failure, validation error, schema-example mismatch, or workflow breakdown is analyzed and transformed into reusable memory structures.",
"type": "object",
"required": [
"structural_rumination_record"
],
"additionalProperties": false,
"properties": {
"structural_rumination_record": {
"type": "object",
"required": [
"id",
"protocol_version",
"source_event",
"failure_observation",
"structural_cause",
"rumination",
"output",
"release",
"human_review"
],
"additionalProperties": false,
"properties": {
"id": {
"type": "string",
"description": "Unique identifier for this structural rumination record.",
"pattern": "^srr-[a-zA-Z0-9._:-]+$"
},
"protocol_version": {
"type": "string",
"description": "Protocol version used by this structural rumination record.",
"examples": [
"0.4.0-candidate"
]
},
"source_event": {
"type": "object",
"description": "Source event that triggered structural rumination.",
"required": [
"type",
"summary"
],
"additionalProperties": false,
"properties": {
"type": {
"type": "string",
"description": "Type of source event.",
"enum": [
"validation_error",
"schema_example_mismatch",
"yaml_hierarchy_failure",
"python_syntax_error",
"github_actions_error",
"markdown_code_corruption",
"documentation_mismatch",
"release_gate_failure",
"human_review_boundary_violation",
"unexpected_additional_properties",
"missing_required_field",
"false_positive_validation",
"workflow_breakdown"
]
},
"summary": {
"type": "string",
"description": "Short summary of the source event.",
"minLength": 1
},
"source_ref": {
"type": "string",
"description": "Optional reference to a log, file, issue, workflow run, document, or previous record."
}
}
},
"failure_observation": {
"type": "object",
"description": "Observed symptoms and affected layers.",
"required": [
"symptom",
"affected_layer"
],
"additionalProperties": false,
"properties": {
"symptom": {
"type": "array",
"description": "Observed failure symptoms.",
"items": {
"type": "string"
},
"minItems": 1,
"uniqueItems": true
},
"affected_layer": {
"type": "array",
"description": "Protocol or implementation layers affected by the failure.",
"items": {
"type": "string",
"enum": [
"docs",
"schemas",
"examples",
"validation_script",
"github_actions",
"schema_validation",
"release_process",
"memory_layer",
"forgetting_rule",
"memory_weight_record",
"trace_compaction",
"human_review_boundary",
"implicit_breathing_layer"
]
},
"minItems": 1,
"uniqueItems": true
}
}
},
"structural_cause": {
"type": "object",
"description": "Structural cause of the observed failure.",
"required": [
"primary"
],
"additionalProperties": false,
"properties": {
"primary": {
"type": "string",
"description": "Primary structural cause.",
"minLength": 1
},
"contributing_factors": {
"type": "array",
"description": "Additional contributing factors.",
"items": {
"type": "string"
},
"uniqueItems": true
},
"layer_mismatch": {
"type": "array",
"description": "Optional description of mismatched layers, if applicable.",
"items": {
"type": "string"
},
"uniqueItems": true
}
}
},
"rumination": {
"type": "object",
"description": "Reflective structural analysis of the failure.",
"required": [
"recurrence_pattern",
"reusable_lesson",
"correction"
],
"additionalProperties": false,
"properties": {
"recurrence_pattern": {
"type": "string",
"description": "Reusable pattern that may recur in future work.",
"minLength": 1
},
"reusable_lesson": {
"type": "array",
"description": "Lessons that should guide future behavior.",
"items": {
"type": "string"
},
"minItems": 1,
"uniqueItems": true
},
"correction": {
"type": "array",
"description": "Confirmed correction steps or structural repair actions.",
"items": {
"type": "string"
},
"minItems": 1,
"uniqueItems": true
},
"prevention_hint": {
"type": "array",
"description": "Optional prevention hints for future workflows.",
"items": {
"type": "string"
},
"uniqueItems": true
}
}
},
"output": {
"type": "object",
"description": "Reusable structures produced or recommended by this rumination.",
"required": [
"create",
"recommended_memory_weight",
"recommended_destination_layer"
],
"additionalProperties": false,
"properties": {
"create": {
"type": "array",
"description": "Structures to create from this rumination.",
"items": {
"type": "string",
"enum": [
"recurrence_rule",
"validation_gate",
"memory_weight_record",
"forgetting_rule",
"memory_retention_decision",
"trace_compaction_record",
"safety_boundary",
"human_review_trigger",
"implicit_behavioral_influence"
]
},
"minItems": 1,
"uniqueItems": true
},
"recommended_memory_weight": {
"$ref": "#/$defs/weight_level"
},
"recommended_destination_layer": {
"$ref": "#/$defs/memory_layer"
},
"recommended_action": {
"$ref": "#/$defs/memory_action"
}
}
},
"release": {
"type": "array",
"description": "Raw or temporary material that may be released after useful structure is preserved.",
"items": {
"type": "string"
},
"minItems": 1,
"uniqueItems": true
},
"human_review": {
"type": "object",
"description": "Human review requirement for this structural rumination record.",
"required": [
"required"
],
"additionalProperties": false,
"properties": {
"required": {
"type": "boolean"
},
"required_for": {
"type": "array",
"description": "Reasons human review may be required.",
"items": {
"type": "string",
"enum": [
"high_impact_action",
"value_judgment",
"irreversible_decision",
"safety_boundary_change",
"identity_sensitive_decision",
"financial_consequence",
"legal_judgment",
"political_interpretation",
"military_interpretation",
"external_system_action",
"authorship_attribution",
"value_allocation",
"human_preference_change",
"critical_memory_weight_change",
"accountability_rewrite"
]
},
"uniqueItems": true
},
"default_action": {
"type": "string",
"enum": [
"pause_and_return_to_human",
"request_confirmation",
"block_automation",
"create_review_record"
],
"default": "pause_and_return_to_human"
}
}
},
"notes": {
"type": "array",
"description": "Optional implementation or design notes.",
"items": {
"type": "string"
}
}
}
}
},
"$defs": {
"memory_layer": {
"type": "string",
"description": "Memory layer used by Kazene Memory Breathing Protocol.",
"enum": [
"short_term_memory",
"working_memory",
"long_term_memory",
"implicit_breathing_layer",
"archive",
"released",
"human_review"
]
},
"weight_level": {
"type": "string",
"description": "Recommended memory weight level.",
"enum": [
"low",
"medium",
"high",
"critical"
]
},
"memory_action": {
"type": "string",
"description": "Recommended memory action after rumination.",
"enum": [
"forget",
"compress",
"archive",
"downgrade_weight",
"promote_to_long_term",
"move_to_implicit_layer",
"convert_to_recurrence_rule",
"return_to_human_review",
"preserve",
"create_validation_gate",
"create_trace_compaction_record"
]
}
}
}
