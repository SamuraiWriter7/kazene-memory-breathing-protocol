{
"$schema": "https://json-schema.org/draft/2020-12/schema",
"$id": "https://github.com/SamuraiWriter7/kazene-memory-breathing-protocol/schemas/trace-compaction-record.schema.json",
"title": "Trace Compaction Record",
"description": "A trace compaction record for Kazene Memory Breathing Protocol, documenting how raw traces, validation logs, failures, or debugging context are compacted into reusable memory structures while releasing unnecessary noise.",
"type": "object",
"required": [
"trace_compaction_record"
],
"additionalProperties": false,
"properties": {
"trace_compaction_record": {
"type": "object",
"required": [
"id",
"protocol_version",
"source_trace",
"preserved",
"transformed_into",
"released",
"compaction_result",
"human_review"
],
"additionalProperties": false,
"properties": {
"id": {
"type": "string",
"description": "Unique identifier for this trace compaction record.",
"pattern": "^tcr-[a-zA-Z0-9.*:-]+$"
},
"protocol_version": {
"type": "string",
"description": "Protocol version used by this trace compaction record.",
"examples": [
"0.4.0-candidate"
]
},
"source_trace": {
"type": "object",
"description": "Source trace being compacted.",
"required": [
"type",
"summary"
],
"additionalProperties": false,
"properties": {
"type": {
"type": "string",
"description": "Type of source trace.",
"enum": [
"validation_error",
"schema_example_mismatch",
"yaml_hierarchy_failure",
"python_syntax_error",
"github_actions_error",
"markdown_code_corruption",
"documentation_mismatch",
"release_gate_failure",
"human_review_boundary_violation",
"unexpected_additional_properties",
"missing_required_field",
"false_positive_validation",
"workflow_breakdown",
"debugging_thread",
"raw_conversation_trace"
]
},
"summary": {
"type": "string",
"description": "Short summary of the trace being compacted.",
"minLength": 1
},
"source_ref": {
"type": "string",
"description": "Optional reference to a log, file, workflow run, issue, document, or previous record."
},
"source_rumination_record": {
"type": "string",
"description": "Optional structural rumination record that produced this compaction.",
"pattern": "^srr-[a-zA-Z0-9.*:-]+$"
}
}
},
"preserved": {
"type": "array",
"description": "Elements preserved from the raw trace.",
"items": {
"type": "string",
"enum": [
"failure_pattern",
"root_cause",
"confirmed_correction",
"recurrence_prevention_rule",
"validation_boundary",
"safety_boundary",
"human_review_boundary",
"schema_requirement",
"example_structure",
"release_gate_condition",
"attribution_context",
"value_sensitive_trace"
]
},
"minItems": 1,
"uniqueItems": true
},
"transformed_into": {
"type": "array",
"description": "Reusable structures created from the compacted trace.",
"items": {
"type": "string",
"enum": [
"recurrence_rule",
"validation_gate",
"memory_weight_record",
"forgetting_rule",
"memory_retention_decision",
"structural_rumination_record",
"safety_boundary",
"human_review_trigger",
"implicit_behavioral_influence",
"archive_record"
]
},
"minItems": 1,
"uniqueItems": true
},
"released": {
"type": "array",
"description": "Raw or temporary material released after compaction.",
"items": {
"type": "string",
"enum": [
"full_traceback",
"duplicate_error_messages",
"temporary_debug_notes",
"resolved_intermediate_context",
"redundant_log_lines",
"obsolete_assumptions",
"repeated_explanations",
"one_time_noise",
"temporary_troubleshooting_chatter"
]
},
"minItems": 1,
"uniqueItems": true
},
"compaction_result": {
"type": "object",
"description": "Outcome of the trace compaction process.",
"required": [
"destination_layer",
"active_context_reduction",
"recurrence_prevention_value",
"recommended_memory_weight"
],
"additionalProperties": false,
"properties": {
"destination_layer": {
"$ref": "#/$defs/memory_layer"
},
"active_context_reduction": {
"$ref": "#/$defs/reduction_level"
},
"recurrence_prevention_value": {
"$ref": "#/$defs/impact_level"
},
"recommended_memory_weight": {
"$ref": "#/$defs/weight_level"
},
"recommended_action": {
"$ref": "#/$defs/memory_action"
},
"review_cycle": {
"$ref": "#/$defs/review_cycle"
}
}
},
"human_review": {
"type": "object",
"description": "Human review requirement for this trace compaction record.",
"required": [
"required"
],
"additionalProperties": false,
"properties": {
"required": {
"type": "boolean"
},
"required_for": {
"type": "array",
"description": "Reasons human review may be required.",
"items": {
"type": "string",
"enum": [
"high_impact_action",
"value_judgment",
"irreversible_decision",
"safety_boundary_change",
"identity_sensitive_decision",
"financial_consequence",
"legal_judgment",
"political_interpretation",
"military_interpretation",
"external_system_action",
"authorship_attribution",
"value_allocation",
"human_preference_change",
"critical_memory_weight_change",
"accountability_rewrite",
"trace_loss_risk"
]
},
"uniqueItems": true
},
"default_action": {
"type": "string",
"enum": [
"pause_and_return_to_human",
"request_confirmation",
"block_automation",
"create_review_record"
],
"default": "pause_and_return_to_human"
}
}
},
"notes": {
"type": "array",
"description": "Optional implementation or design notes.",
"items": {
"type": "string"
}
}
}
}
},
"$defs": {
"memory_layer": {
"type": "string",
"description": "Memory layer used by Kazene Memory Breathing Protocol.",
"enum": [
"short_term_memory",
"working_memory",
"long_term_memory",
"implicit_breathing_layer",
"archive",
"released",
"human_review"
]
},
"weight_level": {
"type": "string",
"description": "Recommended memory weight level.",
"enum": [
"low",
"medium",
"high",
"critical"
]
},
"impact_level": {
"type": "string",
"description": "General impact or value level.",
"enum": [
"low",
"medium",
"high",
"critical"
]
},
"reduction_level": {
"type": "string",
"description": "Degree to which active context load is reduced by compaction.",
"enum": [
"none",
"low",
"medium",
"high",
"critical"
]
},
"review_cycle": {
"type": "string",
"description": "Recommended review cycle for the compacted trace result.",
"enum": [
"none",
"daily",
"weekly",
"monthly",
"quarterly",
"release_cycle",
"on_major_change",
"human_requested"
]
},
"memory_action": {
"type": "string",
"description": "Recommended memory action after trace compaction.",
"enum": [
"forget",
"compress",
"archive",
"downgrade_weight",
"promote_to_long_term",
"move_to_implicit_layer",
"convert_to_recurrence_rule",
"return_to_human_review",
"preserve",
"create_validation_gate",
"create_trace_compaction_record"
]
}
}
}
